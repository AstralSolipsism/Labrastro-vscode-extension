{
  "name": "dogcode",
  "displayName": "dogcode",
  "description": "dogcode central self-hosted coding agent frontend for VS Code",
  "version": "0.1.0",
  "license": "AGPL-3.0-or-later",
  "publisher": "dogcode",
  "icon": "assets/icons/doge.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/AstralSolipsism/dogcode.git"
  },
  "homepage": "https://github.com/AstralSolipsism/dogcode#readme",
  "bugs": {
    "url": "https://github.com/AstralSolipsism/dogcode/issues"
  },
  "activationEvents": [
    "onView:dogcode.SidebarProvider",
    "onCommand:dogcode.newTask",
    "onCommand:dogcode.openSessionHistory",
    "onCommand:dogcode.openSettings",
    "onCommand:dogcode.openAbout",
    "onCommand:dogcode.openAgentManager"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "dogcode-ActivityBar",
          "title": "dogcode",
          "icon": "assets/icons/dogcode-activitybar.svg"
        }
      ]
    },
    "views": {
      "dogcode-ActivityBar": [
        {
          "type": "webview",
          "id": "dogcode.SidebarProvider",
          "name": "dogcode"
        }
      ]
    },
    "commands": [
      {
        "command": "dogcode.newTask",
        "title": "新建对话",
        "icon": "$(add)"
      },
      {
        "command": "dogcode.openSessionHistory",
        "title": "Session History",
        "icon": "$(history)"
      },
      {
        "command": "dogcode.openSettings",
        "title": "Settings",
        "icon": "$(settings-gear)"
      },
      {
        "command": "dogcode.openAbout",
        "title": "About",
        "icon": "$(info)"
      },
      {
        "command": "dogcode.openAgentManager",
        "title": "Open dogcode Trace Preview",
        "icon": "$(list-tree)"
      }
    ],
    "configuration": {
      "title": "dogcode",
      "properties": {
        "dogcode.hostUrl": {
          "type": "string",
          "default": "http://127.0.0.1:8765",
          "description": "dogcode host HTTP base URL."
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "dogcode.newTask",
          "group": "navigation@0",
          "when": "view == dogcode.SidebarProvider"
        },
        {
          "command": "dogcode.openSessionHistory",
          "group": "navigation@0.5",
          "when": "view == dogcode.SidebarProvider"
        },
        {
          "command": "dogcode.openSettings",
          "group": "navigation@1",
          "when": "view == dogcode.SidebarProvider"
        },
        {
          "command": "dogcode.openAbout",
          "group": "navigation@2",
          "when": "view == dogcode.SidebarProvider"
        }
      ]
    }
  },
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "watch:fast": "node esbuild.js --watch --fast",
    "typecheck:extension": "tsc -p tsconfig.json --noEmit",
    "typecheck:webview": "tsc -p webview-ui/tsconfig.json --noEmit",
    "typecheck": "npm run typecheck:extension && npm run typecheck:webview",
    "package": "node esbuild.js --production",
    "package:vsix": "vsce package --out dogcode.vsix",
    "test:auto-approval": "vitest run webview-ui/src/utils/command-auto-approval.test.ts",
    "test:chat": "vitest run webview-ui/src/chat/chatState.test.ts",
    "test:settings": "vitest run webview-ui/src/settings/utils.test.ts"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/shell-quote": "^1.7.5",
    "@types/vscode": "^1.85.0",
    "@vscode/codicons": "^0.0.45",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.24.0",
    "esbuild-plugin-solid": "^0.6.0",
    "solid-js": "^1.9.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "dompurify": "^3.4.1",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.2",
    "shell-quote": "^1.8.3"
  }
}
